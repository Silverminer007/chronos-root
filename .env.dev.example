# Copy this file to .env.dev and fill in the values.
# The Makefile will source it automatically for `make backend`.
#
# The frontend reads its own frontend/.env — copy frontend/.env.example there.

# ── Keycloak ──────────────────────────────────────────────────────────────────
AUTH_SERVER_BASE_URL=https://auth.example.com
AUTH_SERVER_REALM=chronos
AUTH_SERVER_CLIENT_ID=chronos-api
AUTH_SERVER_CLIENT_SECRET=

# ── Web Push (VAPID) — optional in dev ────────────────────────────────────────
VAPID_MAILTO=dev@example.com
VAPID_PUBLIC=
VAPID_PRIVATE=